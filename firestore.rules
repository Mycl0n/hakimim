rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ardabuyukaslan1@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // User Profiles
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ===============================================================
    // Legal Cases
    // ===============================================================
    match /cases/{caseId} {
      // Allow read if owner, or if assigned party2 (by UID or Email)
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || 
        (resource.data.party1 != null && resource.data.party1.uid == request.auth.uid) ||
        (resource.data.party2 != null && (
          resource.data.party2.uid == request.auth.uid ||
          resource.data.party2.email == request.auth.token.email
        )) ||
        isAdmin()
      );

      // Allow create if authenticated and setting themselves as creator
      allow create: if isAuthenticated() && 
        request.resource.data.createdBy == request.auth.uid &&
        (request.resource.data.status == 'defense1' || request.resource.data.status == 'setup');

      // Allow update if owner or assigned party2
      allow update: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid || 
        (resource.data.party2 != null && (
          resource.data.party2.uid == request.auth.uid ||
          resource.data.party2.email == request.auth.token.email
        )) ||
        isAdmin()
      ) && 
      // Immutable fields
      request.resource.data.createdBy == resource.data.createdBy &&
      request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isAdmin();
    }
  }
}
